# ---- One-time EC2 setup ----
#
# Add current user to docker group:
#   sudo usermod -aG docker $USER
#   (log out and back in for it to take effect)
#
# Install certbot:
#   sudo add-apt-repository universe
#   sudo apt-get update
#   sudo apt-get install -y certbot
#
# Generate SSL cert (DNS must already point to this IP):
#   sudo certbot certonly --standalone -d neuralripper.com
#
# ---- AWS Secrets Manager (secret: "neuralripper-prod") ----
#
# MYSQL_ROOT_PASSWORD
# MYSQL_PASSWORD
# JWT_SECRET_KEY
# GOOGLE_CLIENT_ID
# MODAL_TOKEN_ID
# MODAL_TOKEN_SECRET
